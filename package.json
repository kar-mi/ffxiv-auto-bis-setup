{
  "name": "ffxiv_gear_setup",
  "module": "src/server/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/server/index.ts",
    "desktop": "electrobun dev",
    "desktop:build": "electrobun build --env=canary",
    "desktop:build:stable": "electrobun build --env=stable",
    "package:portable": "bun run scripts/package-portable.ts",
    "build": "bun run build:ui",
    "build:css": "tailwindcss -i ./src/ui/styles.css -o ./public/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/ui/styles.css -o ./public/styles.css --watch",
    "build:ui": "bun run build:css && bun build src/ui/main.tsx --outfile public/bundle.js --target browser",
    "build:ui:prod": "bun run build:css && bun build src/ui/main.tsx --outfile public/bundle.js --target browser --minify",
    "watch:ui": "bun build src/ui/main.tsx --outfile public/bundle.js --target browser --watch",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "electrobun": "1.16.0",
    "tailwindcss": "3",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@ffxiv-teamcraft/pcap-ffxiv": "1.2.30",
    "@preact/signals": "^2.9.0",
    "preact": "^10.29.1"
  },
  "trustedDependencies": [
    "@ffxiv-teamcraft/dll-inject"
  ]
}
