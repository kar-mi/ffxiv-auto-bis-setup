{
  "name": "ffxiv_gear_setup",
  "module": "src/server/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/server/index.ts",
    "desktop": "electrobun dev",
    "desktop:build": "electrobun build canary",
    "build:ui": "bun build src/ui/main.ts --outfile public/bundle.js --target browser",
    "watch:ui": "bun build src/ui/main.ts --outfile public/bundle.js --target browser --watch"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "electrobun": "1.16.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@ffxiv-teamcraft/pcap-ffxiv": "1.2.30"
  },
  "trustedDependencies": [
    "@ffxiv-teamcraft/dll-inject"
  ]
}
